<?xml version="1.0" encoding="utf-8"?>
<AbsoluteLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <FrameLayout
        android:id="@+id/frame1"
        android:layout_width="382dp"
        android:layout_height="100dp"
        android:layout_x="13dp"
        android:layout_y="98dp"
        android:background="@drawable/image_view">

        <ImageButton

            android:id="@+id/button5"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout="@drawable/image_view"
            android:background="@drawable/img6" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Kitchen"
            android:textColor="#FFFFFF"
            android:textSize="48dp"
            android:textStyle="bold" />


    </FrameLayout>

    <FrameLayout
        android:id="@+id/frame2"
        android:layout_width="382dp"
        android:layout_height="100dp"
        android:layout_x="13dp"
        android:layout_y="220dp"
        android:background="#9D8FF0">

        <ImageButton
            android:id="@+id/button6"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/hall3" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Hall"
            android:textColor="#FFFFFF"
            android:textSize="48dp"
            android:textStyle="bold" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/frame3"
        android:layout_width="382dp"
        android:layout_height="100dp"
        android:layout_x="13dp"
        android:layout_y="345dp"
        android:background="#9D8FF0">

        <ImageButton
            android:id="@+id/button7"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/kid2" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Kids Room"
            android:textColor="#FFFFFF"
            android:textSize="48dp"
            android:textStyle="bold" />


    </FrameLayout>

    <FrameLayout
        android:id="@+id/frame4"
        android:layout_width="382dp"
        android:layout_height="100dp"
        android:layout_x="13dp"
        android:layout_y="462dp"
        android:background="#9D8FF0">

        <ImageButton
            android:id="@+id/button8"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bed7" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Bed Room"
            android:textColor="#FFFFFF"
            android:textSize="48dp"
            android:textStyle="bold" />

    </FrameLayout>


</AbsoluteLayout>
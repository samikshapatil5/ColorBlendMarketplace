<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/order"
        android:layout_width="335dp"
        android:layout_height="56dp"
        android:layout_marginTop="244dp"
        android:backgroundTint="#9A7BE4"
        android:fontFamily="@font/delius_swash_caps"
        android:text="Place your order now"
        android:textColor="@color/white"


        android:textSize="27dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="HardcodedText,MissingConstraints,SpUsage,TextSizeCheck">

    </com.google.android.material.button.MaterialButton>

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="409dp"
        android:layout_height="385dp"
        android:layout_marginTop="344dp"
        android:importantForAccessibility="no"
        android:src="@drawable/order"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints,ImageContrastCheck" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="249dp"
        android:layout_height="63dp"
        android:layout_marginStart="84dp"
        android:layout_marginTop="116dp"
        android:fontFamily="@font/delius_swash_caps"
        android:text="Transform your "
        android:textColor="#D15858"
        android:textSize="28dp"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="HardcodedText,MissingConstraints,SpUsage" />

    <TextView
        android:id="@+id/textView4"
        android:layout_width="323dp"
        android:layout_height="43dp"
        android:layout_marginTop="164dp"
        android:fontFamily="@font/delius_swash_caps"
        android:text="space with a splash of color!"
        android:textColor="#752F2F"
        android:textSize="25dp"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="HardcodedText,MissingConstraints,SpUsage,TextSizeCheck" />


</androidx.constraintlayout.widget.ConstraintLayout>




<!-- res/values/styles.xml -->
<resources>

    <!-- Custom shape appearance style -->
    <style name="RectangularShapeAppearance" parent="Widget.MaterialComponents.Button">
        <item name="shapeAppearance">@style/ShapeAppearance.Rectangular</item>
    </style>

    <!-- Rectangular shape appearance style -->
    <style name="ShapeAppearance.Rectangular" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopRight">5dp</item>
        <item name="cornerSizeBottomRight">5dp</item>
        <item name="cornerSizeTopLeft">5dp</item>
        <item name="cornerSizeBottomLeft">5dp</item>
    </style>

</resources>

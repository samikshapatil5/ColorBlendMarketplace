<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootview"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/back"
    tools:context=".MainActivity1">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardView"
        android:layout_width="match_parent"

        android:layout_height="70dp"
        app:cardElevation="380dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
            app:theme="@style/ThemeOverlay.AppCompat.ActionBar"
            app:title="Colour's Blend"
            app:titleTextAppearance="@style/AppToolbarTitleText"
            app:titleTextColor="@android:color/white" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardView2"
        android:layout_width="412dp"
        android:layout_height="214dp"
        android:layout_alignParentTop="true"
        android:layout_marginTop="72dp"
        android:layout_x="0dp"
        android:layout_y="4dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="10dp"
        app:cardElevation="10dp">


        <com.denzcoskun.imageslider.ImageSlider
            android:id="@+id/imageSlider"
            android:layout_width="match_parent"
            android:layout_height="237dp"
            android:layout_y="74dp"
            android:scaleType="fitCenter"

            />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/admin"
        android:layout_width="160dp"
        android:layout_height="129dp"
        android:layout_below="@+id/visiual"
        android:layout_alignParentEnd="true"

        android:layout_marginTop="13dp"
        android:layout_marginEnd="10dp"
        app:cardBackgroundColor="#E4F1B5"
        app:cardCornerRadius="10dp"
        app:cardElevation="80dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.069"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imageView6"
            android:layout_width="140dp"
            android:layout_height="80dp"
            android:layout_marginLeft="5dp"
            android:layout_marginTop="3dp"
            android:clickable="false"
            android:focusable="false"
            android:scaleType="center"
            app:srcCompat="@drawable/admin" />

        <TextView
            android:layout_width="145dp"
            android:layout_height="43dp"
            android:layout_marginLeft="40dp"
            android:layout_marginTop="90dp"
            android:clickable="false"
            android:focusable="false"
            android:fontFamily="@font/archivo_black"
            android:text="Admin"
            android:textColor="#170245"
            android:textSize="16sp" />


    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/inspire"
        android:layout_width="160dp"
        android:layout_height="129dp"
        android:layout_below="@+id/cardView2"
        android:layout_alignParentStart="true"
        android:layout_marginStart="10dp"
        android:layout_marginTop="25dp"
        android:layout_x="19dp"
        android:layout_y="280dp"
        app:cardBackgroundColor="#D2DFF4"
        app:cardCornerRadius="10dp"
        app:cardElevation="80dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.93"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <ImageView
            android:id="@+id/imageView"
            android:layout_width="129dp"
            android:layout_height="83dp"
            android:layout_marginLeft="15dp"
            android:clickable="false"
            android:focusable="false"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/palette" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:layout_marginLeft="25dp"
            android:layout_marginTop="90dp"
            android:clickable="false"
            android:focusable="false"
            android:fontFamily="@font/archivo_black"
            android:text="Inspiration"
            android:textColor="#170245"
            android:textSize="16sp" />


    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/visiual"
        android:layout_width="160dp"
        android:layout_height="129dp"
        android:layout_below="@+id/cardView2"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="25dp"
        android:layout_marginEnd="10dp"

        android:layout_x="211dp"
        android:layout_y="300dp"
        app:cardCornerRadius="10dp"
        app:cardBackgroundColor="#F3C4CD"

        app:cardElevation="80dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.069"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="140dp"
            android:layout_height="80dp"
            android:layout_marginLeft="5dp"
            android:layout_marginTop="3dp"
            android:clickable="false"
            android:focusable="false"

            android:scaleType="fitCenter"
            app:srcCompat="@drawable/roller" />


        <TextView
            android:layout_width="160dp"
            android:layout_height="34dp"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="90dp"
            android:clickable="false"
            android:focusable="false"
            android:fontFamily="@font/archivo_black"
            android:text="visualizing"
            android:textColor="#170245"
            android:textSize="16sp" />


    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/painter"
        android:layout_width="160dp"
        android:layout_height="129dp"
        android:layout_below="@+id/inspire"
        android:layout_alignParentStart="true"
        android:layout_marginStart="10dp"

        android:layout_marginTop="13dp"
        app:cardBackgroundColor="#FEFFFF"
        app:cardCornerRadius="10dp"
        app:cardElevation="80dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.93"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <ImageView
            android:id="@+id/imageView3"
            android:layout_width="132dp"
            android:layout_height="67dp"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="3dp"
            android:clickable="false"
            android:focusable="false"
            android:scaleType="centerCrop"
            app:srcCompat="@drawable/painter" />

        <TextView
            android:layout_width="132dp"
            android:layout_height="34dp"
            android:layout_marginLeft="25dp"
            android:layout_marginTop="86dp"
            android:clickable="false"
            android:focusable="false"
            android:fontFamily="@font/archivo_black"
            android:text="Find Painter"
            android:textColor="#170245"
            android:textSize="16sp" />


    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/order"
        android:layout_width="180dp"
        android:layout_height="109dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginTop="594dp"
        android:layout_marginEnd="114dp"
        android:layout_marginBottom="7dp"
        android:layout_x="109dp"
        android:layout_y="589dp"
        app:cardBackgroundColor="#EDD3B6"
        app:cardCornerRadius="10dp"
        app:cardElevation="80dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.93"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="154dp"
            android:layout_height="58dp"
            android:layout_marginLeft="32dp"
            android:layout_marginTop="30dp"
            android:clickable="false"
            android:focusable="false"
            android:fontFamily="@font/archivo_black"
            android:text="Order Now"
            android:textColor="#911313"
            android:textSize="18sp" />
    </androidx.cardview.widget.CardView>


    <!-- Other views in your layout -->

</RelativeLayout>


